            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Laura Martínez\",\n  \"email\": \"laura.martinez@correo.cl\",\n  \"telefono\": \"+56944444444\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/clientes",
          "host": ["{{base_url}}"],
          "path": ["api", "clientes"]
        },
        "description": "Crea un nuevo cliente con datos válidos.\nRespuesta esperada: 201 Created"
      }
    },
    {
      "name": "POST - Email duplicado (409)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Otra Laura\",\n  \"email\": \"laura.martinez@correo.cl\",\n  \"telefono\": \"+56955555555\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/clientes",
          "host": ["{{base_url}}"],
          "path": ["api", "clientes"]
        },
        "description": "Intenta registrar un email ya existente.\nRespuesta esperada: 409 Conflict"
