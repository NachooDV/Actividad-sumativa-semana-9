    },
    {
      "name": "POST - Campos faltantes (400)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Sin Email\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/clientes",
          "host": ["{{base_url}}"],
          "path": ["api", "clientes"]
        },
        "description": "Envía un body sin el campo email.\nRespuesta esperada: 400 Bad Request"
